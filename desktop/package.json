{
    "name": "local-share",
    "productName": "Local Share",
    "version": "1.0.0",
    "description": "Local File Sharing Desktop App",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "build:mac": "electron-builder --mac"
    },
    "dependencies": {
        "bonjour-service": "^1.3.0",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "form-data": "^4.0.5",
        "multer": "^1.4.5-lts.1",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "electron": "^29.0.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.bajrangi.localshare",
        "mac": {
            "category": "public.app-category.utilities",
            "target": "dmg"
        },
        "directories": {
            "output": "out"
        },
        "files": [
            "main.js",
            "server.js",
            "dist/**/*",
            "node_modules/**/*"
        ]
    }
}
